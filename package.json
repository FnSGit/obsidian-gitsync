{
  "name": "obsidian-git-sync",
  "version": "1.0.0",
  "description": "Sync your Obsidian vault with Git repository",
  "main": "dist/main.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FnSGit/obsidian-gitsync.git"
  },
  "bugs": {
    "url": "https://github.com/FnSGit/obsidian-gitsync/issues"
  },
  "homepage": "https://github.com/FnSGit/obsidian-gitsync#readme",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs --production",
    "deploy": "node scripts/dev-deploy.js",
    "package": "node scripts/package.js",
    "release": "npm run build && npm run package",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "obsidian",
    "git",
    "sync",
    "gitee",
    "github"
  ],
  "author": "FnSGit",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.0",
    "jest": "^29.7.0",
    "obsidian": "latest",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "ignore": "^5.3.0",
    "isomorphic-git": "^1.25.0",
    "tslib": "^2.8.1"
  }
}
